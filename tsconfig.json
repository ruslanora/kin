{
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noPropertyAccessFromIndexSignature": false,
    "importHelpers": true,
    "rootDir": ".",
    "paths": {
      "@kin/desktop/*": ["./apps/desktop/src/*"],
      "@kin/extension/*": ["./apps/extension/src/*"],
      "@kin/ui": ["./libs/ui/src"],
      "@kin/ui/*": ["./libs/ui/src/*"]
    }
  },
  "exclude": ["node_modules"]
}
