{
  "manifest_version": 3,
  "name": "Kin",
  "version": "1.0.0",
  "description": "Free, offline, and open-source job search companion",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": { "default_popup": "popup.html" },
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": ["http://127.0.0.1:6767/*"]
}
