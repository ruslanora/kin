{
  "name": "@kin/desktop",
  "productName": "Kin",
  "version": "1.0.0",
  "description": "Free, offline, and open-source job search companion",
  "main": ".vite/build/index.js",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ruslanora/kin.git"
  },
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3,node-mac-permissions --module-dir ../../node_modules/better-sqlite3",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "APPLE_IDENTITY= electron-forge make --targets @electron-forge/maker-zip",
    "make:mas": "electron-forge make --platform darwin --arch arm64 --targets @electron-forge/maker-pkg",
    "make:ci": "APPLE_IDENTITY= electron-forge make --targets @electron-forge/maker-zip",
    "publish": "electron-forge publish",
    "rebuild": "electron-rebuild -f -w better-sqlite3,node-mac-permissions --module-dir ../../node_modules/better-sqlite3",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kin/ui": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "electron-log": "^5.4.3",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "node-mac-permissions": "^2.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "update-electron-app": "^3.1.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-pkg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
