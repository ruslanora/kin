{
  "name": "kin",
  "version": "1.0.0",
  "description": "Free, offline, and open-source job search companion",
  "main": "index.js",
  "license": "AGPL-3.0",
  "author": "Ruslan Ora",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruslanora/kin.git"
  },
  "engines": {
    "node": ">=23.11.1 <=25.9.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "typecheck": "pnpm --filter ./apps/desktop run typecheck && pnpm --filter ./libs/ui run typecheck && pnpm --filter ./apps/extension run typecheck && pnpm --filter ./apps/server run typecheck",
    "prepare": "husky",
    "app:start": "pnpm --filter ./apps/desktop run start",
    "app:package": "pnpm --filter ./apps/desktop run package",
    "app:make": "pnpm --filter ./apps/desktop run make",
    "app:make:all": "pnpm --filter ./apps/desktop run make:mac",
    "app:rebuild": "pnpm --filter ./apps/desktop run rebuild",
    "app:publish": "pnpm --filter ./apps/desktop run publish",
    "app:generate": "pnpm --filter ./apps/desktop run generate",
    "app:migrate": "pnpm --filter ./apps/desktop run migrate",
    "app:studio": "pnpm --filter ./apps/desktop run studio",
    "ui:build": "pnpm --filter ./libs/ui run build",
    "ui:test": "pnpm --filter ./libs/ui run test",
    "ui:stories": "pnpm --filter ./libs/ui run storybook",
    "ext:build": "pnpm --filter ./apps/extension run build",
    "ext:dev": "pnpm --filter ./apps/extension run dev",
    "server:dev": "pnpm --filter ./apps/server run dev",
    "server:build": "pnpm --filter ./apps/server run build",
    "server:start": "pnpm --filter ./apps/server run start",
    "server:generate": "pnpm --filter ./apps/server run generate",
    "server:migrate": "pnpm --filter ./apps/server run migrate",
    "server:studio": "pnpm --filter ./apps/server run studio"
  },
  "pnpm": {
    "overrides": {
      "@tiptap/core": "3.22.1",
      "@tiptap/react": "3.22.1",
      "@tiptap/starter-kit": "3.22.1",
      "@tiptap/extension-placeholder": "3.22.1"
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
